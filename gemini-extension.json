{
  "name": "visual-story-planner",
  "version": "0.1.0",
  "description": "Gemini CLI extension for story analysis, validation, exports, and reusable story planning prompts.",
  "tools": [
    {
      "name": "analyze_story",
      "description": "Analyze story text and generate StoryGraph JSON"
    },
    {
      "name": "export_mermaid",
      "description": "Convert StoryGraph to Mermaid diagram"
    },
    {
      "name": "export_canvas",
      "description": "Convert StoryGraph to Canvas JSON"
    },
    {
      "name": "export_dashboard",
      "description": "Generate interactive HTML dashboard"
    },
    {
      "name": "export_markdown",
      "description": "Convert StoryGraph to Markdown document"
    },
    {
      "name": "validate_story_structure",
      "description": "Comprehensive story structure validation"
    },
    {
      "name": "extract_characters",
      "description": "Extract and analyze characters"
    },
    {
      "name": "extract_conflicts",
      "description": "Extract and analyze conflicts"
    },
    {
      "name": "build_relationship_graph",
      "description": "Build relationship graph between elements"
    }
  ]
}
